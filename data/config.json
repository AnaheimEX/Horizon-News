{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-v4-flash",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "zh"
    ],
    "analysis_concurrency": 5,
    "enrichment_concurrency": 5
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "xxx@qq.com",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": false,
      "fetch_top_stories": 0,
      "min_score": 0
    },
    "rss": [
      {
        "name": "IGN Games",
        "url": "http://feeds.feedburner.com/ign/games-all",
        "enabled": true,
        "category": "games"
      },
      {
        "name": "GameSpot Game News",
        "url": "https://www.gamespot.com/feeds/game-news/",
        "enabled": true,
        "category": "games"
      },
      {
        "name": "Eurogamer News",
        "url": "https://www.eurogamer.net/feed/news",
        "enabled": true,
        "category": "games"
      },
      {
        "name": "Kotaku via Google News",
        "url": "https://news.google.com/rss/search?q=site%3Akotaku.com%20games%20OR%20gaming&hl=en-US&gl=US&ceid=US:en",
        "enabled": true,
        "category": "games"
      },
      {
        "name": "Video Games Chronicle",
        "url": "https://www.videogameschronicle.com/feed/",
        "enabled": true,
        "category": "games"
      },
      {
        "name": "GameWith via Google News",
        "url": "https://news.google.com/rss/search?q=site%3Agamewith.jp%20%E3%82%B2%E3%83%BC%E3%83%A0&hl=ja&gl=JP&ceid=JP:ja",
        "enabled": true,
        "category": "games"
      },
      {
        "name": "Famitsu via Google News",
        "url": "https://news.google.com/rss/search?q=site%3Afamitsu.com%20%E3%82%B2%E3%83%BC%E3%83%A0&hl=ja&gl=JP&ceid=JP:ja",
        "enabled": true,
        "category": "games"
      },
      {
        "name": "GAME Watch via Google News",
        "url": "https://news.google.com/rss/search?q=site%3Agame.watch.impress.co.jp%20%E3%82%B2%E3%83%BC%E3%83%A0&hl=ja&gl=JP&ceid=JP:ja",
        "enabled": true,
        "category": "games"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [],
      "users": [],
      "fetch_comments": 0
    },
    "telegram": {
      "enabled": false,
      "channels": []
    },
    "ossinsight": {
      "enabled": false,
      "period": "past_24_hours",
      "languages": [],
      "keywords": [],
      "min_stars": 0,
      "max_items": 0
    }
  },
  "filtering": {
    "ai_score_threshold": 5.5,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "Horizon生成结果: #{result}\nHorizon日报重要资讯数量: #{important_items}/#{all_items}"
            },
            {
              "tag": "hr"
            },
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
